// Race Results
model RaceResult {
  id        Int @id @default(autoincrement())
  eventId   Int
  studentId Int

  // Race Details
  raceType      String // e.g., "500M", "1000M"
  skateCategory String // e.g., "QUAD", "INLINE"
  ageCategory   String // e.g., "U-14"
  gender        Gender

  // Result
  position Int // 1, 2, 3
  timing   String? // Optional timing info (e.g., "00:45:12")
  remarks  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event   Event   @relation(fields: [eventId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([eventId, raceType, skateCategory, ageCategory, gender, position]) // Ensure unique winner per slot
  @@index([eventId])
  @@index([studentId])
  @@map("race_results")
}

// ==========================================
// COACH CERTIFICATION MODELS
// ==========================================

model CoachCertProgram {
  id          Int     @id @default(autoincrement())
  level       Int // 1, 2, 3
  title       String
  description String? @db.Text

  // Schedule
  startDate       DateTime
  endDate         DateTime
  lastDateToApply DateTime

  // Location
  venue        String
  venueAddress String?
  city         String
  state        String

  // Pricing
  price        Decimal @db.Decimal(10, 2)
  includesText String? // e.g. "Includes 2 days dormitory stay, food & camp fees"

  // Capacity
  totalSeats  Int
  filledSeats Int @default(0)

  // Eligibility
  eligibilityCriteria String? @db.Text
  minAge              Int?
  minExperience       Int? // in years
  prerequisiteLevel   Int? // Must have completed this level first (null for Level 1)

  // Status
  status   String  @default("DRAFT") // DRAFT, PUBLISHED, REGISTRATION_OPEN, REGISTRATION_CLOSED, ONGOING, COMPLETED, CANCELLED
  isActive Boolean @default(true)

  // Organizer Info
  organizedBy String?
  approvedBy  String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  registrations CoachCertRegistration[]

  @@index([level])
  @@index([status])
  @@index([startDate])
  @@index([isActive, status])
  @@map("coach_cert_programs")
}

model CoachCertRegistration {
  id        Int @id @default(autoincrement())
  programId Int

  // Personal Details
  fullName    String
  fatherName  String
  gender      String // MALE, FEMALE, OTHER
  dateOfBirth DateTime

  // Contact
  phone String
  email String

  // Address
  address  String @db.Text
  city     String
  district String
  state    String
  pincode  String

  // Skating Details
  bloodGroup        String?
  skatingExperience Int? // in years
  tshirtSize        String?

  // Documents
  photo         String? // file path
  aadhaarNumber String
  aadhaarCard   String? // file path

  // Registration
  registrationNumber String   @unique // SSFI-COACH-L1-001
  registrationDate   DateTime @default(now())

  // Payment
  amount        Decimal @db.Decimal(10, 2)
  paymentStatus String  @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  paymentId     String?
  transactionId String?

  // Completion & Certification
  status              String    @default("REGISTERED") // REGISTERED, PAYMENT_PENDING, CONFIRMED, ATTENDED, COMPLETED, FAILED, CANCELLED
  isCompleted         Boolean   @default(false)
  completedAt         DateTime?
  rating              Decimal?  @db.Decimal(2, 1) // 1.0 to 5.0
  remarks             String?   @db.Text
  certificateNumber   String?
  certificateIssuedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  program CoachCertProgram @relation(fields: [programId], references: [id])
  payment Payment?

  @@unique([programId, phone])
  @@unique([programId, aadhaarNumber])
  @@index([programId])
  @@index([status])
  @@index([isCompleted])
  @@index([registrationNumber])
  @@map("coach_cert_registrations")
}

