{
  "name": "ssfi-backend",
  "version": "1.0.0",
  "description": "Skating Sports Federation of India - Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "npx tsc --noEmitOnError false || true",
    "postinstall": "prisma generate",
    "prestart": "node -e \"require('fs').writeFileSync('.env', Object.entries(process.env).filter(([k])=>['DATABASE_URL','JWT_SECRET','JWT_REFRESH_SECRET','ENCRYPTION_KEY','JWT_EXPIRE','JWT_REFRESH_EXPIRE','FRONTEND_URL','ALLOWED_ORIGINS','SMTP_HOST','SMTP_PORT','SMTP_USER','SMTP_PASS','APP_URL','NODE_ENV','PORT','API_VERSION'].includes(k)).map(([k,v])=>k+'='+v).join('\\n'))\"",
    "start": "node dist/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "seed:locations": "ts-node prisma/seed-locations.ts",
    "test:email": "ts-node -r tsconfig-paths/register src/scripts/test-email.ts"
  },
  "keywords": ["ssfi", "skating", "federation", "sports"],
  "author": "SSFI Team",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.22",
    "@types/pdfkit": "^0.13.4",
    "@types/uuid": "^9.0.7",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.14.0",
    "prisma": "^5.8.0",
    "razorpay": "^2.9.6",
    "sharp": "^0.33.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "twilio": "^4.20.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2"
  }
}
